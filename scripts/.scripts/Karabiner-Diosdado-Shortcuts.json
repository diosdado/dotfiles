{ "description": "Diosdado-Shortcuts", "manipulators": [



{
    "description": "Application to Apple FN Layer", "type": "basic",
    "from": { "key_code": "application" },
    "to": [{ "apple_vendor_top_case_key_code": "keyboard_fn" }]
},





{
    "description": "Delete to equal+cmd", "type": "basic",
    "from": { "key_code": "insert" },
    "to": [{ "key_code": "equal_sign", "modifiers": ["command"] }],
    "conditions":[{
        "bundle_identifiers":[
            "org.inkscape.Inkscape",
            "org.gimp.gimp"
        ],
        "type": "frontmost_application_unless"
    }]
},
{
    "description": "Insert to hyphen+cmd", "type": "basic",
    "from": { "key_code": "delete_forward" },
    "to": [{ "key_code": "hyphen", "modifiers":["command"] }],
    "conditions":[{
        "bundle_identifiers":[
            "org.inkscape.Inkscape",
            "org.gimp.gimp"
        ],
        "type": "frontmost_application_unless"
    }]
},



{
    "description": "Delete to plus sign", "type": "basic",
    "from": { "key_code": "insert" },
    "to": [{ "key_code": "equal_sign", "modifiers": ["shift"] }],
    "conditions":[{
        "bundle_identifiers":[
            "org.inkscape.Inkscape",
            "org.gimp.gimp"
        ],
        "type": "frontmost_application_if"
    }]
},
{
    "description": "Insert to hyphen", "type": "basic",
    "from": { "key_code": "delete_forward" },
    "to": [{ "key_code": "hyphen" }],
    "conditions":[{
        "bundle_identifiers":[
            "org.inkscape.Inkscape",
            "org.gimp.gimp"
        ],
        "type": "frontmost_application_if"
    }]
},





{
    "description": "Disable hide window","type": "basic",
    "from": { "key_code": "h", "modifiers": { "mandatory":["command"]} },
    "to": [{ "key_code": "vk_none" }]
},
{
    "description": "Disable minimize window","type": "basic",
    "from": { "key_code": "m", "modifiers": { "mandatory":["command"]} },
    "to": [{ "key_code": "vk_none" }]
},



{
    "description": "Escape to Applications Layer","type": "basic",
    "from": { "key_code": "escape", "modifiers": { "optional": ["left_command", "left_shift", "left_option", "left_control", "caps_lock"] } },
    "parameters": { "basic.to_if_alone_timeout_milliseconds": 150, "basic.to_if_held_down_threshold_milliseconds": 0 },
    "to": [
        { "set_variable": { "name": "app_layer", "value": 1 } },
        { "shell_command": "~/.scripts/yabai/switch-layer.sh -l apps" }
    ],
    "to_after_key_up": [
        { "key_code": "vk_none" },
        { "set_variable": { "name": "app_layer", "value": 0 } },
        { "shell_command": "~/.scripts/yabai/switch-layer.sh -l default" }
    ],
    "to_if_alone": [ { "key_code": "escape" } ],
    "to_if_held_down": [ { "key_code": "vk_none", "modifiers": [] } ]
},

{
    "description": "Caps to Applications Layer","type": "basic",
    "from": { "key_code": "caps_lock", "modifiers": { "optional": ["left_command", "left_shift", "left_option", "left_control", "caps_lock"] } },
    "parameters": { "basic.to_if_alone_timeout_milliseconds": 150, "basic.to_if_held_down_threshold_milliseconds": 0 },
    "to": [
        { "set_variable": { "name": "app_layer", "value": 1 } },
        { "shell_command": "~/.scripts/yabai/switch-layer.sh -l apps" }
    ],
    "to_after_key_up": [
        { "key_code": "vk_none" },
        { "set_variable": { "name": "app_layer", "value": 0 } },
        { "shell_command": "~/.scripts/yabai/switch-layer.sh -l default" }
    ],
    "to_if_alone": [ { "key_code": "escape" } ],
    "to_if_held_down": [ { "key_code": "vk_none", "modifiers": [] } ]
},




{
    "description": "Command two times to Show Desktop","type": "basic",
    "conditions": [ { "name": "left_command pressed", "type": "variable_if", "value": 1 } ],
    "from": { "key_code": "left_command", "modifiers": { "optional": ["any"] } },
    "to": [{ "shell_command": "/opt/homebrew/bin/yabai -m space --toggle show-desktop" }]
},
{
    "from": { "key_code": "left_command", "modifiers": { "optional": ["any"] } },
    "to": [ { "set_variable": { "name": "left_command pressed", "value": 1 } }, { "key_code": "left_command" } ],
    "to_delayed_action": {
        "to_if_canceled": [ { "set_variable": { "name": "left_command pressed", "value": 0 } } ],
        "to_if_invoked": [ { "set_variable": { "name": "left_command pressed", "value": 0 } } ]
    }, "type": "basic"
},



{
    "description": "Option two times to Mission Control","type": "basic",
    "conditions": [ { "name": "left_option pressed", "type": "variable_if", "value": 1 } ],
    "from": { "key_code": "left_option", "modifiers": { "optional": ["any"] } },
    "to": [{ "key_code": "mission_control" }]
},
{
    "from": { "key_code": "left_option", "modifiers": { "optional": ["any"] } },
    "to": [ { "set_variable": { "name": "left_option pressed", "value": 1 } }, { "key_code": "left_option" } ],
    "to_delayed_action": {
        "to_if_canceled": [ { "set_variable": { "name": "left_option pressed", "value": 0 } } ],
        "to_if_invoked": [ { "set_variable": { "name": "left_option pressed", "value": 0 } } ]
    }, "type": "basic"
}






] }
