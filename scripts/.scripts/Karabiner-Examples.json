{

"description": "F12 to F12 for Cursor app",

"manipulators": [
    {
        "conditions": [
            {
                "bundle_identifiers": [
                    "com.todesktop.230313mzl4w4u92"
                ],
                "file_paths": ["/Applications/Cursor.app/Contents/MacOS/Cursor"],
                "type": "frontmost_application_if"
            }

        ]
        "from": { "key_code": "f12" },
        "to": [{ "key_code": "f12" }],
        "type": "basic"
    }

]

}




{
    "conditions": [ { "name": "app_layer", "type": "variable_if", "value": 1 } ], "type": "basic",
    "from": { "key_code": "open_bracket" },
    "to": [{ "shell_command": "cat ~/clipboard/cp_comma.txt | tr -d '\n' | pbcopy" }],
    "to_after_key_up": [ { "key_code": "v", "modifiers": ["command"] } ]
},
{
    "conditions": [ { "name": "app_layer", "type": "variable_if", "value": 1 } ], "type": "basic",
    "from": { "key_code": "close_bracket" },
    "to": [{ "shell_command": "cat ~/clipboard/cp_period.txt | tr -d '\n' | pbcopy" }],
    "to_after_key_up": [ { "key_code": "v", "modifiers": ["command"] } ]
}
